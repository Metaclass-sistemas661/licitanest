# =============================================================================
# LICITANEST — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env
# =============================================================================

# --- Firebase (Frontend) ---
VITE_FIREBASE_API_KEY=sua-api-key-aqui
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto

# --- API Backend (Cloud Run) ---
VITE_API_URL=http://localhost:8080

# --- App ---
VITE_APP_NAME=LicitaNest
VITE_APP_URL=http://localhost:5173

# --- E-mail (Cotação Eletrônica) ---
VITE_EMAIL_FROM=cotacao@licitanest.com.br

# --- Google Cloud (server-side — NÃO prefixe com VITE_) ---
# DB_HOST=34.39.190.88
# DB_NAME=licitanest
# DB_USER=postgres
# DB_PASSWORD=sua-senha-aqui

# --- Integrações / APIs (server-side) ---
# PNCP_API_URL=https://pncp.gov.br/api/consulta/v1
# RESEND_API_KEY=re_xxxxxxxxxxxx
