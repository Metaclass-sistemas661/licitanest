{
  "hosting": {
    "target": "licitanest",
    "public": "dist",
    "cleanUrls": false,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/home.html"
      },
      {
        "source": "/login",
        "destination": "/index.html"
      },
      {
        "source": "/recuperar-senha",
        "destination": "/index.html"
      },
      {
        "source": "/redefinir-senha",
        "destination": "/index.html"
      },
      {
        "source": "/onboarding",
        "destination": "/index.html"
      },
      {
        "source": "/portal/**",
        "destination": "/index.html"
      },
      {
        "source": "/catalogo",
        "destination": "/index.html"
      },
      {
        "source": "/cestas/**",
        "destination": "/index.html"
      },
      {
        "source": "/cotacoes/**",
        "destination": "/index.html"
      },
      {
        "source": "/fornecedores",
        "destination": "/index.html"
      },
      {
        "source": "/pesquisa-rapida",
        "destination": "/index.html"
      },
      {
        "source": "/relatorios",
        "destination": "/index.html"
      },
      {
        "source": "/configuracoes",
        "destination": "/index.html"
      },
      {
        "source": "/painel-gestor",
        "destination": "/index.html"
      },
      {
        "source": "/ajuda",
        "destination": "/index.html"
      },
      {
        "source": "/comparador",
        "destination": "/index.html"
      },
      {
        "source": "/templates-cestas",
        "destination": "/index.html"
      },
      {
        "source": "/historico-precos",
        "destination": "/index.html"
      },
      {
        "source": "/mapa-calor",
        "destination": "/index.html"
      },
      {
        "source": "/alertas-preco",
        "destination": "/index.html"
      },
      {
        "source": "/exportacao-sicom",
        "destination": "/index.html"
      },
      {
        "source": "/sugestao-fontes-ia",
        "destination": "/index.html"
      },
      {
        "source": "/ocr-cotacoes",
        "destination": "/index.html"
      },
      {
        "source": "/billing",
        "destination": "/index.html"
      },
      {
        "source": "/metricas-uso",
        "destination": "/index.html"
      },
      {
        "source": "/notificacoes",
        "destination": "/index.html"
      },
      {
        "source": "/api-publica",
        "destination": "/index.html"
      },
      {
        "source": "/admin-metaclass",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/firebase-messaging-sw.js",
        "headers": [
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          }
        ]
      },
      {
        "source": "**/*.@(js|css|map)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=2592000"
          }
        ]
      }
    ]
  }
}
