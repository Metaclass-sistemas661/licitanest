{
  "name": "licitanest",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de Formação e Elaboração de Cestas de Preços para Compras Públicas",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node -e \"require('fs').renameSync('dist/index.html','dist/app.html')\"",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "keywords": [
    "licitacao",
    "cesta-precos",
    "compras-publicas"
  ],
  "author": "Metaclass",
  "license": "UNLICENSED",
