    <!-- EMBRULHANDO HERO NUM STICKY WRAPPER PARA EFEITO DE ENTRADA E BORDAS FLUTUANTES -->
    <div class="hero-wrapper">

        <section class="hero" id="hero">
            <!-- VÍDEO DO MAPA (FREEPIK) COM BLEND MODE SCREEN -->
            <video class="hero-bg-map" id="hero-map" autoplay loop muted playsinline>
                <source src="../public/video-3d.mp4" type="video/mp4">
            </video>

            <!-- TEXTO COM COPY ALINHADA AO MAPA B2B -->
            <div class="hero-content">
                <div class="badge hero-badge">
                    <div class="badge-dot"
                        style="background: var(--gradient-start); box-shadow: 0 0 10px var(--gradient-start);"></div>
                    <span
                        style="color: var(--text-secondary); font-size: 0.85rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase;">Mapeamento
                        Nacional</span>
                </div>
                <h1 class="hero-title" data-split-text>A <span>Cesta de Preços</span> definitiva.</h1>
                <p class="hero-subtitle hero-sub-anim">
                    Inteligência de dados consolidada de todo o país. Obtenha valores precisos do PNCP, TCEs e Painel de
                    Preços em segundos, documentados e prontos para auditoria.
                </p>
                <div class="cta-group hero-cta-anim">
                    <a href="#" class="btn btn-primary magnetic-wrap">
                        Montar Cesta Agora
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </a>
                    <a href="#" class="btn btn-secondary">
                        Ver como funciona
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="5 3 19 12 5 21 5 3"></polygon>
                        </svg>
                    </a>
                </div>
            </div>


            <!-- FAIXA DE INTEGRAÇÕES (MARQUEE INFINITO) -->
            <style>
                .integrations-banner {
                    position: relative;
                    width: 100%;
                    padding: 1rem 0 3rem 0;
                    /* Padding superior menor para colar embaixo do Hero */
                    background: transparent;
                    overflow: hidden;
                    z-index: 10;
                }

                .integrations-track {
                    display: flex;
                    align-items: center;
                    gap: 4rem;
                    width: max-content;
                    animation: scroll-left 30s linear infinite;
                }

                @keyframes scroll-left {
                    0% {
                        transform: translateX(0);
                    }

                    100% {
                        transform: translateX(-50%);
                    }
                }

                /* Criando a máscara suave nas bordas para as logos sumirem devagar */
                .integrations-banner::before,
                .integrations-banner::after {
                    content: '';
                    position: absolute;
                    top: 0;
                    width: 150px;
                    height: 100%;
                    z-index: 2;
                }

                .integrations-banner::before {
                    left: 0;
                    background: linear-gradient(to right, #f3f4f6 0%, transparent 100%);
                }

                .integrations-banner::after {
                    right: 0;
                    background: linear-gradient(to left, #f3f4f6 0%, transparent 100%);
                }

                .integration-item {
                    display: flex;
                    align-items: center;
                    gap: 0.75rem;
                    font-family: 'Inter', sans-serif;
                    font-weight: 600;
                    font-size: 1.1rem;
                    /* Um pouco maior pra leitura */
                    color: #4b5563;
                    /* cinza mais escuro do tailwind para ler no fundo claro */
                    letter-spacing: 0.05em;
                    transition: color 0.3s ease, transform 0.3s ease;
                }

                .integration-item:hover {
                    color: var(--gradient-end);
                    /* Azul ao passar o mouse */
                    transform: scale(1.05);
                    /* Leve pop up */
                }

                .integration-icon {
                    width: 24px;
                    height: 24px;
                    opacity: 1;
                    /* Sem opacidade reduzida */
                    color: var(--gradient-end);
                    /* Ícone azul elétrico */
                }
            </style>



        </section>
    </div>

