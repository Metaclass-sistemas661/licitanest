    </section>

    <!-- NOVA SEÇÃO: Texto Minimalista Estilo Apple Financial (Baseada na Captura) -->
    <style>
        .clean-features {
            background-color: transparent;
            padding: 2rem 5% 8rem 5%;
            /* Padding reduzido no topo para aproximar dos logos */
            font-family: 'Inter', sans-serif;
            color: #111827;
            /* Preto/Cinza bem escuro para texto limpo no fundo f3f4f6 */
            position: relative;
            overflow: hidden;
        }

        /* Fade suave na base da seção para eliminar transição brusca com o fundo do body */
        .clean-features::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 200px;
            background: linear-gradient(to bottom, transparent, #f3f4f6);
            z-index: 15;
            pointer-events: none;
        }

        .clean-features-container {
            max-width: 1200px;
            margin: 0 auto;
            /* Centraliza a coluna de texto grossa na tela */
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
            /* Centraliza verticalmente o texto e a imagem */
        }

        .clean-features-text {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        /* --- VISUAL MOCKUP 3D (ESQUERDA) --- */
        .cf-visual {
            position: relative;
            width: 100%;
            height: 600px;
            display: flex;
            align-items: center;
            justify-content: center;
            perspective: 1200px;
            /* Profundidade do 3D */
            z-index: 5;
        }

        /* Orbs Desfocados de Luz */
        .cf-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(50px);
            opacity: 0.6;
            z-index: 1;
            animation: float-orb 8s infinite alternate ease-in-out;
        }

        .cf-orb-1 {
            width: 250px;
            height: 250px;
            background: rgba(139, 92, 246, 0.4);
            /* Roxo vibrante clarinho */
            top: 10%;
            right: 15%;
            animation-delay: 0s;
        }

        .cf-orb-2 {
            width: 300px;
            height: 300px;
            background: rgba(168, 85, 247, 0.3);
            /* Lilás */
            bottom: 5%;
            left: 5%;
            animation-delay: -3s;
        }

        @keyframes float-orb {
            0% {
                transform: translate(0, 0) scale(1);
            }

            100% {
                transform: translate(-40px, 50px) scale(1.1);
            }
        }

        /* Orbs Desfocados de Luz para Atmosfera sem Fundo Quadrado */
        .cf-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            opacity: 0.5;
            z-index: 1;
            animation: float-orb 8s infinite alternate ease-in-out;
        }

        .cf-orb-1 {
            width: 350px;
            height: 350px;
            background: rgba(139, 92, 246, 0.4);
            /* Roxo */
            top: 20%;
            right: -5%;
            animation-delay: 0s;
        }

        .cf-orb-2 {
            width: 400px;
            height: 400px;
            background: rgba(6, 182, 212, 0.3);
            /* Ciano (Accent Licitanest) */
            bottom: 5%;
            left: -10%;
            animation-delay: -3s;
        }

        @keyframes float-orb {
            0% {
                transform: translate(0, 0) scale(1);
            }

            100% {
                transform: translate(-30px, 40px) scale(1.1);
            }
        }

        /* Imagem Renderizada Licitacao.png (Escala Massiva) */
        .cf-image-render {
            width: 260%;
            /* Escala colossal para rasgar totalmente o lado esquerdo */
            max-width: none;
            object-fit: contain;
            position: relative;
            z-index: 10;
            margin-left: -50%;
            margin-right: -20%;
            margin-bottom: -15%;

            /* Sombra colossal projetada no formato celular com drop-shadow */
            filter: drop-shadow(-40px 60px 80px rgba(0, 0, 0, 0.3)) drop-shadow(0 10px 20px rgba(6, 182, 212, 0.25));
            transform: translateY(0px) rotate(-2deg);
        }

        .cf-image-render:hover {
            filter: drop-shadow(-40px 70px 100px rgba(0, 0, 0, 0.4)) drop-shadow(0 10px 30px rgba(6, 182, 212, 0.4));
        }



        .clean-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 3.5rem;
            font-weight: 700;
            line-height: 1.1;
            margin-bottom: 2rem;
            letter-spacing: -0.03em;
            color: #030712;
            /* Quase preto */
        }

        .clean-paragraph {
            font-size: 1.125rem;
            line-height: 1.7;
            color: #6b7280;
            /* Cinza médio/claro igual a referência */
            margin-bottom: 3rem;
            max-width: 90%;
        }

        .clean-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 1rem;
            font-weight: 600;
            color: #111827;
            text-decoration: none;
            margin-bottom: 1.5rem;
            transition: gap 0.3s ease;
        }

        .clean-link:hover {
            gap: 0.8rem;
            /* Seta move sutilmente no hover */
        }

        .clean-divider {
            width: 100%;
            height: 1px;
            background-color: #d1d5db;
            /* Linha finíssima cinza claro */
            margin: 3rem 0;
        }

        /* Os "Tags/Botões" pretos embaixo da linha */
        .clean-bottom-features {
            display: flex;
            gap: 3rem;
            flex-wrap: wrap;
        }

        .cbf-item {
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }

        .cbf-icon-box {
            width: 60px;
            height: 60px;
            background-color: #030712;
            /* Fundo preto sólido */
            border-radius: 16px;
            /* Borda bem arredondada (squircle style) */
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            flex-shrink: 0;
        }

        .cbf-text {
            font-size: 1rem;
            font-weight: 500;
            line-height: 1.4;
            color: #111827;
            max-width: 150px;
        }

        @media (max-width: 900px) {
            .clean-features-container {
                grid-template-columns: 1fr;
            }

            .cf-visual {
                margin-bottom: 0;
                transform: scale(0.9);
            }

            .clean-title {
                font-size: 3rem;
            }
        }

        @media (max-width: 768px) {
            .clean-title {
                font-size: 2.5rem;
            }

            .clean-bottom-features {
                flex-direction: column;
                gap: 2rem;
            }
        }
    </style>

    <section class="clean-features section-reveal" id="solucoes">
        <div class="clean-features-container">

            <!-- Coluna 1: O Visual (Tamanho Expandido com Atmosfera) -->
            <div class="cf-visual">
                <!-- Atmosfera Traseira -->
                <div class="cf-orb cf-orb-1"></div>
                <div class="cf-orb cf-orb-2"></div>

                <!-- Imagem Original (Flutuante Gigante) - Sem fundo -->
                <img src="../public/licitacao.png" alt="Tela Licitanest" class="cf-image-render" />
            </div>

            <!-- Coluna 2: Textos Editoriais -->
            <div class="clean-features-text">
                <h2 class="clean-title">
                    Automação cirúrgica<br>
                    para a Gestão Pública.
                </h2>

                <p class="clean-paragraph">
                    Mais do que varrer fontes, o Licitanest decodifica as regras do jogo. Preços inexequíveis e lances
                    viciados são isolados em tempo real pela nossa IA. Chega de refazer cestas inteiras por causa de um
                    outlier que destruiu a média da sua licitação.
                </p>

                <a href="#" class="clean-link">
                    Filtro Bayesiano Anti-Lixo em ação
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                        stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>

                <p class="clean-paragraph" style="margin-bottom: 1rem; color: #9ca3af; font-size: 1rem;">
                    Milhares de fontes simultâneas vasculhadas, em menos de três segundos. Modelos matemáticos refinam a
                    pesquisa entregando uma amostra pura, livre de lances "suicidas" de leilões fracassados com
                    documentação passo-a-passo.
                </p>

                <div class="clean-divider"></div>

                <div class="clean-bottom-features">

                    <div class="cbf-item">
                        <div class="cbf-icon-box">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                                <path d="M8 14h.01"></path>
                                <path d="M12 14h.01"></path>
                                <path d="M16 14h.01"></path>
                                <path d="M8 18h.01"></path>
                                <path d="M12 18h.01"></path>
                                <path d="M16 18h.01"></path>
                            </svg>
                        </div>
                        <div class="cbf-text">
                            Acesso em tempo real aos TCEs e PNCP
                        </div>
                    </div>

                    <div class="cbf-item">
                        <div class="cbf-icon-box">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                                <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                            </svg>
                        </div>
                        <div class="cbf-text">
                            Blindagem Total: Logs de rastreio em PDF
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </section>

    <!-- SEÇÃO: Processo Simplificado (Inspirada Referência Visual) -->
    <style>
        .process-section {
            background-color: #f3f4f6;
            padding: 6rem 5%;
            font-family: 'Inter', sans-serif;
            position: relative;
            z-index: 10;
        }
        .process-container {
            max-width: 1200px;
            margin: 0 auto;
        }
        .process-header {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: start;
            margin-bottom: 5rem;
        }
        .process-header-left h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 3.2rem;
            font-weight: 700;
            line-height: 1.08;
            color: #030712;
            letter-spacing: -0.03em;
        }
        .process-header-left h2 span {
            color: var(--gradient-end, #0284c7);
        }
        .process-header-right {
            padding-top: 0.5rem;
        }
        .process-header-right p {
            font-size: 1.1rem;
            color: #4b5563;
            line-height: 1.7;
            margin-bottom: 2rem;
        }
        .process-cta-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 1rem;
            font-weight: 600;
            color: #030712;
            text-decoration: none;
            border-bottom: 2px solid #030712;
            padding-bottom: 4px;
            transition: color 0.3s, border-color 0.3s;
        }
        .process-cta-link:hover {
            color: var(--gradient-end, #0284c7);
            border-color: var(--gradient-end, #0284c7);
        }

        /* Steps Grid: 3 colunas */
        .process-steps {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }

        .process-step {
            background: #ffffff;
            border-radius: 60px 12px 60px 12px;
            padding: 2.5rem 2rem;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(0,0,0,0.04);
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
        }
        .process-step:hover {
            transform: translateY(-6px);
            box-shadow: 0 30px 60px rgba(0,0,0,0.08);
        }

        .process-step-number {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 5rem;
            font-weight: 700;
            color: rgba(0,0,0,0.04);
            line-height: 1;
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
        }

        .process-step-icon {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.75rem;
            flex-shrink: 0;
        }
        .process-step:nth-child(1) .process-step-icon {
            background: linear-gradient(135deg, #dbeafe, #eff6ff);
            color: #2563eb;
        }
        .process-step:nth-child(2) .process-step-icon {
            background: linear-gradient(135deg, #d1fae5, #ecfdf5);
            color: #059669;
        }
        .process-step:nth-child(3) .process-step-icon {
            background: linear-gradient(135deg, #e0e7ff, #eef2ff);
            color: #4f46e5;
        }

        .process-step h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.35rem;
            font-weight: 700;
            color: #030712;
            margin-bottom: 0.75rem;
            line-height: 1.2;
        }
        .process-step p {
            font-size: 0.95rem;
            color: #6b7280;
            line-height: 1.65;
            margin: 0;
        }

        .process-step-tag {
            display: inline-block;
            margin-top: 1.25rem;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            background: #f1f5f9;
            color: #475569;
        }

        @media (max-width: 900px) {
            .process-header {
                grid-template-columns: 1fr;
                gap: 2rem;
                margin-bottom: 3rem;
            }
            .process-header-left h2 {
                font-size: 2.5rem;
            }
            .process-steps {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <section class="process-section section-reveal" id="processo">
        <div class="process-container">
            <!-- Header: Título à esquerda, descrição à direita -->
            <div class="process-header">
                <div class="process-header-left">
                    <h2>Sua pesquisa de preços,<br><span>em três passos.</span></h2>
                </div>
                <div class="process-header-right">
                    <p>
                        Crie cestas completas como quem faz um PIX. Nossa IA varre PNCP, TCEs e Painel de Preços em segundos enquanto você cuida do que importa: a estratégia da contratação.
                    </p>
                    <a href="#" class="process-cta-link">
                        Ver demonstração ao vivo
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </a>
                </div>
            </div>

            <!-- Steps Grid -->
            <div class="process-steps">
                <!-- Step 1 -->
                <div class="process-step">
                    <span class="process-step-number">01</span>
                    <div class="process-step-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    </div>
                    <h3>Defina o objeto</h3>
                    <p>Digite a descrição do item ou cole o CATMAT/CATSER. A IA sugere automaticamente especificações e unidades de medida compatíveis com o Art. 23 da Lei 14.133.</p>
                    <span class="process-step-tag">Autocompletar IA</span>
                </div>

                <!-- Step 2 -->
                <div class="process-step">
                    <span class="process-step-number">02</span>
                    <div class="process-step-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                    </div>
                    <h3>Coleta automática</h3>
                    <p>O motor varre simultaneamente PNCP, Painel de Preços, Atas de RP e TCEs municipais. Outliers são isolados pelo filtro Bayesiano antes de compor a amostra final.</p>
                    <span class="process-step-tag">6 fontes simultâneas</span>
                </div>

                <!-- Step 3 -->
                <div class="process-step">
                    <span class="process-step-number">03</span>
                    <div class="process-step-icon">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
                    </div>
                    <h3>Relatório pronto</h3>
                    <p>Em segundos, você exporta o PDF com memória de cálculo, gráficos comparativos e justificativa técnica formatada nos padrões exigidos pelo TCE e CGU.</p>
                    <span class="process-step-tag">Pronto para auditoria</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ================================================================================
         NOVA SEÇÃO: FUNCIONALIDADES + BANNER ESCURO (Referência: Cards + Dark CTA)
    ================================================================================ -->
    <style>
        /* --- SEÇÃO FUNCIONALIDADES --- */
        .features-section {
            background-color: #f3f4f6;
            padding: 100px 5% 60px;
        }

        .features-section-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 3rem;
            font-weight: 700;
            text-align: center;
            color: #030712;
            margin-bottom: 4rem;
            letter-spacing: -0.03em;
            line-height: 1.2;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px 40px;
            max-width: 1200px;
            margin: 0 auto 80px;
        }

        .feature-item {
            display: flex;
            align-items: stretch;
            gap: 0;
        }

        .feature-item-icon {
            width: 140px;
            min-width: 140px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            position: relative;
            z-index: 2;
            background: white;
            mix-blend-mode: multiply;
        }

        .feature-item-icon img {
            width: 130px;
            height: 130px;
            object-fit: contain;
        }

        .feature-item-box {
            background: #f3f4f6;
            border-radius: 40px 8px 40px 8px; /* Formato folha assimétrico */
            padding: 1.25rem 1.75rem 1.25rem 1.25rem;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 0.25rem;
            position: relative;
            margin-left: -16px;
            transition: all 0.3s ease;
        }

        .feature-item:hover .feature-item-box {
            background: #e9eaed;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }

        .feature-item-box-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .feature-item-label {
            font-size: 0.7rem;
            font-weight: 500;
            color: #9ca3af;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .feature-item-arrow {
            font-size: 1.1rem;
            color: #9ca3af;
            transition: all 0.3s ease;
        }

        .feature-item:hover .feature-item-arrow {
            color: #030712;
            transform: translateX(3px);
        }

        .feature-item-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            color: #030712;
            line-height: 1.3;
        }

        /* esconder desc antigo */
        .feature-card,
        .feature-card-icon,
        .feature-card-header,
        .feature-card-arrow,
        .feature-card-label,
        .feature-card-title,
        .feature-card-desc {
            display: none;
        }

        /* --- BANNER ESCURO CTA --- */
        .dark-banner {
            max-width: 1200px;
            margin: 0 auto;
            background: #030712;
            border-radius: 32px;
            padding: 60px;
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 3rem;
            align-items: center;
            overflow: hidden;
            position: relative;
        }

        .dark-banner::before {
            content: '';
            position: absolute;
            bottom: -50%;
            left: -20%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(6, 182, 212, 0.15) 0%, transparent 70%);
            pointer-events: none;
        }

        .dark-banner-text {
            position: relative;
            z-index: 2;
        }

        .dark-banner-title {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 2.5rem;
            font-weight: 700;
            color: #e2e8f0;
            margin-bottom: 1.5rem;
            line-height: 1.2;
            letter-spacing: -0.03em;
        }

        .dark-banner-desc {
            font-size: 1.1rem;
            line-height: 1.7;
            color: #94a3b8;
            margin-bottom: 2rem;
        }

        .dark-banner-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            padding: 1rem 2rem;
            background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 25px -5px var(--accent-glow);
        }

        .dark-banner-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px -5px var(--accent-glow);
        }

        .dark-banner-visual {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2;
        }

        .dark-banner-img {
            width: 100%;
            max-width: 500px;
            object-fit: contain;
            filter: drop-shadow(0 40px 80px rgba(0, 0, 0, 0.5));
        }

        .dark-banner-social {
            position: absolute;
            bottom: 20px;
            right: 0;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .dark-banner-avatars {
            display: flex;
        }

        .dark-banner-avatars span {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 2px solid #030712;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            color: white;
            margin-left: -8px;
        }

        .dark-banner-avatars span:first-child {
            margin-left: 0;
            background: #06b6d4;
        }

        .dark-banner-avatars span:nth-child(2) {
            background: #8b5cf6;
        }

        .dark-banner-avatars span:nth-child(3) {
            background: #f59e0b;
        }

        .dark-banner-avatars span:nth-child(4) {
            background: rgba(255, 255, 255, 0.1);
            border: 2px dashed #64748b;
            font-size: 1rem;
        }

        .dark-banner-rating {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .dark-banner-rating .star {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: #f59e0b;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 0.85rem;
        }

        .dark-banner-rating .rating-text {
            font-size: 0.85rem;
            color: #94a3b8;
            line-height: 1.3;
        }

        .dark-banner-rating .rating-text strong {
            color: #e2e8f0;
        }

        @media (max-width: 900px) {
            .features-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .dark-banner {
                grid-template-columns: 1fr;
                padding: 40px 30px;
            }

            .dark-banner-visual {
                order: -1;
            }
        }

        @media (max-width: 600px) {
            .features-grid {
                grid-template-columns: 1fr;
            }

            .features-section-title {
                font-size: 2.2rem;
            }

            .dark-banner-title {
                font-size: 2rem;
            }
        }
    </style>

