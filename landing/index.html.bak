        .mf-logo-main .logo-sub { color: rgba(255,255,255,0.5); font-size: 0.55rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; margin-top: 0; }
        .mf-logo-main span { color: #06b6d4; }
