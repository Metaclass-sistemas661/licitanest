{
  "name": "licitanest-api",
  "version": "1.0.0",
  "description": "API REST LicitaNest — Cloud Run + Fastify",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^7.14.0",
    "@google-cloud/vertexai": "^1.10.4",
    "@sentry/node": "^10.47.0",
    "fastify": "^5.2.0",
    "firebase-admin": "^13.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-forge": "^1.4.0",
    "otplib": "^13.4.0",
    "pg": "^8.13.0",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.17",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.11.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
